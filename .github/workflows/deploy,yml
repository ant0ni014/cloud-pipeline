name: Deploy to OTC Server

on:
  push:
    branches:
      - main  # Wird ausgeführt, sobald du auf den 'main' Branch pushst

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          script: |
            cd ~/meine-cloud-app || cd ~/otc-project  # <-- Passe diesen Pfad an deinen Ordner auf der ECS an!
            git pull origin main
            sudo docker build -t meine-cloud-app .
            sudo docker stop webapp || true
            sudo docker rm webapp || true
            sudo docker run -d -p 127.0.0.1:8080:8080 --name webapp meine-cloud-app